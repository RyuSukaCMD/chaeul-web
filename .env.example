# ═══ Konfigurasi Chaeul Web (salin ke .env) ═══
PORT=3000
PUBLIC_URL=https://your-domain.com

# ── Token internal ──
# ADMIN_TOKEN — login dashboard /admin & kelola lisensi via bot
ADMIN_TOKEN=ganti-dengan-token-rahasia-admin
# SYNC_TOKEN — bot push data user/grup & ambil job provisioning
SYNC_TOKEN=ganti-dengan-token-rahasia-sync

# ── Payment (opsional) ──
# Kosongkan semua = mode placeholder (konfirmasi manual via WA).
# Isi salah satu untuk mengaktifkan gateway.

# Midtrans
# MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx
# MIDTRANS_PRODUCTION=false
# Client key (dipakai di frontend, opsional untuk Snap popup)
# MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx

# Xendit
# XENDIT_SECRET_KEY=xnd_development_xxxx
# XENDIT_CALLBACK_TOKEN=xxxx

# Paksa mode tertentu (opsional): midtrans | xendit | placeholder
# PAYMENT_MODE=placeholder
